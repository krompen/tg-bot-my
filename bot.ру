# ========== БАЗА ДАННЫХ ==========
DB_NAME = "database.db"

def init_db():
    conn = sqlite3.connect(DB_NAME)
    c = conn.cursor()
    # Таблица пользователей
    c.execute('''CREATE TABLE IF NOT EXISTS users (
        user_id INTEGER PRIMARY KEY,
        username TEXT,
        first_name TEXT,
        last_name TEXT,
        joined_date TEXT,
        last_active TEXT,
        is_banned INTEGER DEFAULT 0
    )''')
    # Таблица логов
    c.execute('''CREATE TABLE IF NOT EXISTS logs (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        user_id INTEGER,
        command TEXT,
        timestamp TEXT
    )''')
    # Таблица шаблонов ответов
    c.execute('''CREATE TABLE IF NOT EXISTS templates (
        keyword TEXT PRIMARY KEY,
        response TEXT
    )''')
    conn.commit()
    conn.close()

def add_user(user_id, username, first_name, last_name):
    conn = sqlite3.connect(DB_NAME)
    c = conn.cursor()
    now = datetime.datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    c.execute('''INSERT OR IGNORE INTO users (user_id, username, first_name, last_name, joined_date, last_active)
                 VALUES (?, ?, ?, ?, ?, ?)''',
              (user_id, username, first_name, last_name, now, now))
    conn.commit()
    conn.close()

def update_last_active(user_id):
    conn = sqlite3.connect(DB_NAME)
    c = conn.cursor()
    now = datetime.datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    c.execute('UPDATE users SET last_active = ? WHERE user_id = ?', (now, user_id))
    conn.commit()
    conn.close()

def log_command(user_id, command):
    conn = sqlite3.connect(DB_NAME)
    c = conn.cursor()
    now = datetime.datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    c.execute('INSERT INTO logs (user_id, command, timestamp) VALUES (?, ?, ?)', (user_id, command, now))
    conn.commit()
    conn.close()

def is_banned(user_id):
    conn = sqlite3.connect(DB_NAME)
    c = conn.cursor()
    c.execute('SELECT is_banned FROM users WHERE user_id = ?', (user_id,))
    row = c.fetchone()
    conn.close()
    return row and row[0] == 1

def ban_user(user_id):
    conn = sqlite3.connect(DB_NAME)
    c = conn.cursor()
    c.execute('UPDATE users SET is_banned = 1 WHERE user_id = ?', (user_id,))
    conn.commit()
    conn.close()

def unban_user(user_id):
    conn = sqlite3.connect(DB_NAME)
    c = conn.cursor()
    c.execute('UPDATE users SET is_banned = 0 WHERE user_id = ?', (user_id,))
    conn.commit()
    conn.close()

def get_all_users():
    conn = sqlite3.connect(DB_NAME)
    c = conn.cursor()
    c.execute('SELECT user_id, username, first_name, last_name, joined_date, last_active, is_banned FROM users')
    users = c.fetchall()
    conn.close()
    return users

def get_template_response(keyword):
    conn = sqlite3.connect(DB_NAME)
    c = conn.cursor()
    c.execute('SELECT response FROM templates WHERE keyword = ?', (keyword.lower(),))
    row = c.fetchone()
    conn.close()
    return row[0] if row else None

def add_template(keyword, response):
    conn = sqlite3.connect(DB_NAME)
    c = conn.cursor()
    c.execute('INSERT OR REPLACE INTO templates (keyword, response) VALUES (?, ?)', (keyword.lower(), response))
    conn.commit()
    conn.close()

def delete_template(keyword):
    conn = sqlite3.connect(DB_NAME)
    c = conn.cursor()
    c.execute('DELETE FROM templates WHERE keyword = ?', (keyword.lower(),))
    conn.commit()
    conn.close()

def get_all_templates():
    conn = sqlite3.connect(DB_NAME)
    c = conn.cursor()
    c.execute('SELECT keyword, response FROM templates')
    templates = c.fetchall()
    conn.close()
    return templates

# ========== КЛАВИАТУРЫ ==========
def main_keyboard():
    keyboard = [["🕒 Время", "📝 Совет"], ["❓ Помощь"]]
    return ReplyKeyboardMarkup(keyboard, resize_keyboard=True)

def admin_keyboard():
    keyboard = [
        ["📊 Статистика", "📢 Рассылка"],
        ["👥 Пользователи", "🔨 Бан/Разбан"],
        ["📝 Шаблоны", "🔙 Назад"]
    ]
